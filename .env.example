# ╔════════════════════════════════════════════════════════════╗
# ║       Binance Futures Testnet — Environment Config        ║
# ╚════════════════════════════════════════════════════════════╝
#
# SETUP:
#   1. Create a free testnet account → https://testnet.binancefuture.com
#   2. Navigate to API Management and generate a new API key pair.
#   3. Copy this file:
#          cp .env.example .env        (Linux/macOS)
#          copy .env.example .env      (Windows)
#   4. Replace the placeholder values below with your actual keys.
#
# SECURITY:
#   • .env is listed in .gitignore — it will NEVER be committed.
#   • Never share your secret key with anyone.
#   • Rotate keys immediately if they are exposed.
#
# ────────────────────────────────────────────────────────────

# Binance Futures Testnet API credentials
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_SECRET_KEY=your_testnet_secret_key_here

# Testnet base URL (do NOT change unless Binance migrates the endpoint)
BASE_URL=https://testnet.binancefuture.com

# Logging level for the file handler
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG
